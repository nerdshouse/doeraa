{% if settings.goBuynowEnable %}             
<button type="button" class="shopify-payment-button__button shopify-payment-button__button--unbranded" onclick="safeGoKwikBuyNow(this)" id="gokwik-buy-now"{% if settings.hideFlow %} style="button-background: 96 82 82 / var(--button-background-opacity, 1);--button-outline-color: 96 82 82;--button-text-color: 255 255 255;" {% endif %}>{{ settings.buynow-titile }}
<div style="display:none"><div class="cir-loader">Loading..</div></div>
</button>  
{% endif %}

<script>
  const GOKWIK_BUNDLE_PRODUCT_IDS = [8001599865086, 8001573290238, 8001597571326];

  if (typeof window.safeGoKwikBuyNow !== 'function') {
    window.safeGoKwikBuyNow = async function (btn) {
      const getFormBoundInput = function (form, name) {
        if (!form || !name) return null;
        const local = Array.from(form.querySelectorAll('[name="' + name + '"]'));
        const bound = form.id
          ? Array.from(document.querySelectorAll('[name="' + name + '"][form="' + form.id + '"]'))
          : [];
        const all = local.concat(bound);
        return all.length ? all[0] : null;
      };

      try {
        if (btn) btn.disabled = true;

        const form = btn ? btn.closest('form') : null;
        if (!form) throw new Error('Missing product form for GoKwik buy-now');

        const cartBeforeResponse = await fetch('/cart.js', { credentials: 'same-origin' });
        const cartBefore = cartBeforeResponse.ok ? await cartBeforeResponse.json() : { item_count: 0, items: [] };

        // Reset any helper bundle lines and clear current cart for true "Buy Now this product" behavior.
        const bagCleanupUpdates = {};
        (cartBefore.items || []).forEach(function (item) {
          if (GOKWIK_BUNDLE_PRODUCT_IDS.includes(item.product_id)) {
            bagCleanupUpdates[item.key] = 0;
          }
        });

        if (Object.keys(bagCleanupUpdates).length || (cartBefore.item_count || 0) > 0) {
          await fetch('/cart/update.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            credentials: 'same-origin',
            body: JSON.stringify({ updates: bagCleanupUpdates }),
          });

          await fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              Accept: 'application/json',
            },
            credentials: 'same-origin',
          });
        }

        // Variant input can be disabled in this theme when variant picker JS manages state.
        const enabledVariantInput = form.querySelector('input[name="id"]:not([disabled])') || getFormBoundInput(form, 'id');
        const anyVariantInput = form.querySelector('input[name="id"]') || getFormBoundInput(form, 'id');
        const variantId = (enabledVariantInput && enabledVariantInput.value) || (anyVariantInput && anyVariantInput.value);

        if (!variantId) {
          throw new Error('Missing variant id for GoKwik buy-now');
        }

        const qtyInput =
          getFormBoundInput(form, 'quantity') ||
          form.querySelector('[name="quantity"]') ||
          form.querySelector('quantity-selector .quantity-selector__input') ||
          document.querySelector('.shopify-section--main-product .quantity-selector .quantity-selector__input');
        const quantity = Math.max(parseInt(qtyInput && qtyInput.value, 10) || 1, 1);

        const payload = {
          items: [
            {
              id: Number(variantId),
              quantity: quantity,
            },
          ],
        };

        const sellingPlanInput = form.querySelector('input[name="selling_plan"]');
        if (sellingPlanInput && sellingPlanInput.value) {
          payload.items[0].selling_plan = sellingPlanInput.value;
        }

        const addResponse = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/json',
          },
          credentials: 'same-origin',
          body: JSON.stringify(payload),
        });

        if (!addResponse.ok) {
          throw new Error('Buy now add-to-cart failed');
        }

        // Ensure cart state is updated before handing over to GoKwik popup.
        for (let i = 0; i < 4; i += 1) {
          const cartResponse = await fetch('/cart.js', { credentials: 'same-origin' });
          if (cartResponse.ok) {
            const cart = await cartResponse.json();
            if ((cart.item_count || 0) >= 1) {
              break;
            }
          }
          await new Promise(function (resolve) {
            setTimeout(resolve, 180);
          });
        }

        if (typeof window.onCheckoutClick === 'function') {
          window.onCheckoutClick(btn);
          return;
        }

        if (typeof window.onBuyNowClick === 'function') {
          window.onBuyNowClick(btn);
          return;
        }

        window.location.href = '/checkout';
      } catch (error) {
        console.error('GoKwik buy-now sync failed', error);
        alert('Buy Now could not start for the selected product. Please re-select variant/quantity and try again.');
      } finally {
        if (btn) btn.disabled = false;
      }
    };
  }
</script>
