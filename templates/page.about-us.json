-da07-4a26-9468-4818afc43720","template--16607580291326__4813cc7e-7f63-4ffa-b0ee-2fabe5bc43e9-16697937977377bdae-1","template--16607580291326__4813cc7e-7f63-4ffa-b0ee-2fabe5bc43e9-16697937977377bdae-2"],"settings":{"full_width":true,"content_width":"small","text_position":"center","background":"","background_gradient":"","text_color":""}},"4a7c34b8-ab82-4a14-b106-62291012fe76":{"type":"media-with-text","blocks":{"template--16607580291326__4a7c34b8-ab82-4a14-b106-62291012fe76-16697940421782cde2-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Desktop_14_f9a3d42a-bcea-41a6-8ee8-cc00d7db7e53.jpg","media_width":50,"media_position":"end","text_position":"place-self-center text-center","icon":"none","icon_width":48,"title":"Who we are?","content":"<p>Doeraa is a brand that is all about empowering people to make a positive impact on the world through their fashion choices. We believe that every product has the power to make a difference. In addition to our commitment to sustainability, we also believe in giving back to the community. <br\/><br\/>So who are we? We are a group of fashion-conscious individuals who are passionate about making a positive impact on the world through the products we create and sell. We invite you to join us on our mission to make a difference, one product at a time.<\/p>","link_text":"","link_url":"","background":"#1d3b4a","background_gradient":"","text_color":"#ffffff","text_gradient":"","button_background":"","button_text_color":""}}},"block_order":["template--16607580291326__4a7c34b8-ab82-4a14-b106-62291012fe76-16697940421782cde2-0"],"settings":{"full_width":false,"enable_parallax":false,"spacing":"none"}},"e55b5f74-d99e-41fd-852b-026ed6821cf2":{"type":"about-profile","blocks":{"fbb4b512-784d-470d-acd1-63dffb9010b6":{"type":"profile","settings":{"image":"shopify:\/\/shop_images\/image_5_1.png","count":"08","title":"In-house <br>Designers"}},"1c190fb6-f3fa-4684-a8ec-12a58193fcc6":{"type":"profile","settings":{"image":"shopify:\/