<div {% render 'section-properties' %}>
<div class="section-stack">
      {%- render 'section-header', subheading: section.settings.subheading, heading: section.settings.title, heading_color: section.settings.heading_color, heading_gradient: section.settings.heading_gradient, content: section.settings.content, link_text: section.settings.link_text, link_url: section.settings.link_url -%}

<div class="main-gift-wrapper">
{% for block in section.blocks %}
  {% if  block.settings.image != blank %}
<div class="gift-card-cstm">
  <div class="inner-gift-card">
    <img src="{{ block.settings.image | img_url : 'master' }}">
    <div class="gift-cont">
      <p class="headinggift">{{ block.settings.heading }}</p>
      <h3 class="amount-cstm">{{ block.settings.ammount }}</h3>
    </div>
  </div>
</div>
  {% endif %}
  {% endfor %}
</div>
</div>
</div>
{% schema %}
  {
    "name": "Gift card",
    "class":"cstm-gift-card",
    "settings": [
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full width",
        "default": true
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Heading"
      },
      {
        "type": "richtext",
        "id": "content",
        "label": "Content"
      },
      {
        "type": "url",
        "id": "link_url",
        "label": "Link URL"
      },
      {
        "type": "text",
        "id": "link_text",
        "label": "Link text"
      },
      {
        "type": "header",
        "content": "Colors",
        "info": "Gradient replaces solid colors when set."
      },
      {
        "type": "color",
        "id": "background",
        "label": "Background"
      },
      {
        "type": "color_background",
        "id": "background_gradient",
        "label": "Background gradient"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "heading_color",
        "label": "Heading color"
      },
      {
        "type": "color_background",
        "id": "heading_gradient",
        "label": "Heading gradient"
      }
    ],
    "blocks":[
      {
        "type":"gift-card",
        "name":"Gift card",
        "settings":[
          {
            "type":"image_picker",
            "id":"image",
            "label":"Image"
          },
          {
            "type":"text",
            "id":"heading",
            "label":"Title",
            "default":"Gift Card"
          },
          {
            "type":"text",
            "id":"ammount",
            "label":"Ammount"
          }
        ]
      }
    ],
    "presets":[
      {
        "name":"Gift card",
        "category":"custom"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}