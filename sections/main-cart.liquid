<div class="container">
  {%- if cart.item_count == 0 -%}
    <div class="empty-state">
      <div class="empty-state__icon-wrapper">
        {%- render 'icon' with 'cart', width: 32, height: 32, stroke_width: 1 -%}
        <span class="count-bubble count-bubble--lg">0</span>
      </div>

      <div class="prose">
        <p class="h4">{{ 'cart.general.empty' | t }}</p>

        {%- assign button_content = 'cart.general.continue_shopping' | t -%}
        {%- render 'button', href: settings.cart_empty_button_link, size: 'xl', content: button_content -%}
      </div>
    </div>
  {%- else -%}
    <div class="page-spacer">
      <div class="cart">
        <div class="cart-header">
          <h1 class="h2">{{ 'cart.general.title' | t }}</h1>

          {%- render 'cart-progress-bar' -%}
        </div>

        <div class="cart-order">
          <div class="cart-order__summary">
            {%- comment -%}
              ----------------------------------------------------------------------------------------------------------------
              ORDER SUMMARY
              ----------------------------------------------------------------------------------------------------------------
            {%- endcomment -%}
            <table class="order-summary">
              <thead class="order-summary__header">
                <tr>
                  <th>{{ 'customer.order.product' | t }}</th>
                  <th class="w-0">{{ 'customer.order.quantity' | t }}</th>
                  <th class="text-end">{{ 'customer.order.total' | t }}</th>
                </tr>
              </thead>

              <tbody class="order-summary__body">
                {%- for line_item in cart.items -%}
                  {% if line_item.product.id != 8001599865086
                    and line_item.product.id != 8001573290238
                    and line_item.product.id != 8001597571326
                  %}
                    {%- assign line_max_quantity = '' -%}

                    {%- if line_item.variant.inventory_management != blank
                      and line_item.variant.inventory_policy == 'deny'
                    -%}
                      {%- assign line_max_quantity = line_item.variant.inventory_quantity -%}
                    {%- endif -%}

                    <tr
  class="cart-item"
  data-line-key="{{ line_item.key }}"
  data-max-qty="
    {% if line_item.variant.inventory_management != blank 
       and line_item.variant.inventory_policy == 'deny' %}
      {{ line_item.variant.inventory_quantity }}
    {% else %}
      9999
    {% endif %}
  "
>

                      <td>{%- render 'line-item', line_item: line_item -%}</td>

                      <td class="hidden align-center text-center text-subdued sm:table-cell">
                        <line-item-quantity class="v-stack justify-center gap-2">
                          <div class="cart-button">
                            <button type="button" class="cart-mini">-</button>

                            <input
                              class="quantity-input"
                              type="text"
                              readonly
                              is="quantity-input"
                              inputmode="numeric"
                              {% if line_max_quantity != blank %}
                                max="{{ line_max_quantity }}"
                              {% endif %}
                              data-line-key="{{ line_item.key }}"
                              aria-label="{{ 'cart.order.change_quantity' | t | escape }}"
                              value="{% if line_max_quantity != blank and line_item.quantity > line_max_quantity %}{{ line_max_quantity }}{% else %}{{ line_item.quantity }}{% endif %}"
                            >

                            {% comment %} <input class="quantity-input" type="text" readonly is="quantity-input" inputmode="numeric" {% if line_max_quantity != blank %}max="{{ line_max_quantity }}"{% endif %} data-line-key="{{ line_item.key }}" aria-label="{{ 'cart.order.change_quantity' | t | escape }}" value="{{ line_item.quantity }}"> {% endcomment %}
                            <button type="button" class="cart-plus">+</button>
                          </div>
                          {%- for line_item_sub in cart.items -%}
                            {% if line_item_sub.product.id == 8001599865086
                              or line_item_sub.product.id == 8001573290238
                              or line_item_sub.product.id == 8001597571326
                            %}
                              {% if line_item.properties._bundleid == line_item_sub.properties._bundleid %}
                                {% assign vkey = forloop.index %}
                              {% endif %}
                            {% endif %}
                          {%- endfor -%}
                          <span class="text-xs">
                            <a href="{{ line_item.url_to_remove }}" data-subkey="{{ vkey }}" class="link">
                              {{- 'cart.order.remove' | t -}}
                            </a>
                          </span>
                        </line-item-quantity>
                      </td>
                      {% comment %} {% assign final_line_price = line_item.final_line_price %} {% endcomment %}
                       {% if line_max_quantity != blank and line_item.quantity > line_max_quantity %}
  {% assign final_line_price = line_item.final_price | times: line_max_quantity %}
{% else %}
  {% assign final_line_price = line_item.final_line_price %}
{% endif %}

                      {%- for line_item_sub in cart.items -%}
                        {% if line_item_sub.product.id == 8001599865086
                          or line_item_sub.product.id == 8001573290238
                          or line_item_sub.product.id == 8001597571326
                        %}
                          {% if line_item.properties._bundleid == line_item_sub.properties._bundleid %}
                            {% assign sub_qty = line_item_sub.quantity %}
{% if line_max_quantity != blank and sub_qty > line_max_quantity %}
  {% assign sub_qty = line_max_quantity %}
{% endif %}
{% assign final_line_price = final_line_price | plus: line_item_sub.final_price | times: sub_qty %}

                            {% comment %} {% assign final_line_price = final_line_price | plus: line_item_sub.final_line_price %} {% endcomment %}
                          {% endif %}
                        {% endif %}
                      {%- endfor -%}
                      <td class="hidden align-center text-subdued text-end sm:table-cell">
                        <span class="bcpo-cart-item-line-price" data-key="{{line_item.key}}">
                          {{- final_line_price | money -}}
                        </span>
                      </td>
                    </tr>
                  {% endif %}
                {%- endfor -%}
              </tbody>
            </table>

            {%- comment -%}
              ----------------------------------------------------------------------------------------------------------------
              SHIPPING ESTIMATOR
              ----------------------------------------------------------------------------------------------------------------
            {%- endcomment -%}

            {%- assign items_requiring_shipping = cart.items | where: 'requires_shipping' -%}

            {%- if section.settings.show_shipping_estimator and items_requiring_shipping.size > 0 -%}
              {%- assign accordion_title = 'cart.shipping_estimator.estimate_shipping' | t -%}
              {%- capture accordion_content -%}{%- render 'shipping-estimator' -%}{%- endcapture -%}

              {%- render 'accordion',
                title: accordion_title,
                icon: 'picto-box',
                content: accordion_content,
                size: 'lg'
              -%}
            {%- endif -%}
          </div>

          {% assign safe_cart_total = 0 %}

{% for item in cart.items %}
  {% assign max_qty = '' %}

  {% if item.variant.inventory_management != blank and item.variant.inventory_policy == 'deny' %}
    {% assign max_qty = item.variant.inventory_quantity %}
  {% endif %}

  {% if max_qty != blank and item.quantity > max_qty %}
    {% assign line_total = item.final_price | times: max_qty %}
  {% else %}
    {% assign line_total = item.final_line_price %}
  {% endif %}

  {% assign safe_cart_total = safe_cart_total | plus: line_total %}
{% endfor %}

          <safe-sticky class="cart-order__recap v-stack gap-6">
            <form action="{{ routes.cart_url }}" method="POST" class="cart-form rounded">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when '@app' -%}
                    {%- render block -%}

                  {%- when 'totals' -%}
                    <div class="cart-form__totals v-stack gap-2" {{ block.shopify_attributes }}>
                      {%- if block.settings.show_order_weight -%}
                        <div class="h-stack gap-4 justify-between">
                          <span class="text-subdued">{{ 'cart.general.weight' | t }}</span>
                          <span class="text-subdued">{{ cart.total_weight | weight_with_unit }}</span>
                        </div>
                      {%- endif -%}

                      <div class="h-stack gap-4 justify-between">
                        {% comment %}
                          <span class="text-subdued">{{ 'cart.general.subtotal' | t }}</span>
                          <span class="text-subdued"><span class="bcpo-cart-original-total">{{ cart.items_subtotal_price | money }}</span></span>
                        {% endcomment %}
                        <!-- Subtotal -->
                        {% comment %}
                          <span class="bcpo-cart-subtotal">
                            {{ cart.items_subtotal_price | money }}
                          </span>
                        {% endcomment %}

                        <!-- Total -->
                        {% comment %}
                          <span class="bcpo-cart-total">
                            {{ cart.total_price | money_with_currency }}
                          </span>
                        {% endcomment %}
                      </div>

                      {% for discount_application in cart.cart_level_discount_applications %}
                        <div class="h-stack gap-4 justify-between">
                          <div class="badge">
                            {%- render 'icon' with 'discount' -%}
                            {{- discount_application.title -}}
                          </div>

                          <span class="text-subdued">-{{ discount_application.total_allocated_amount | money }}</span>
                        </div>
                      {% endfor %}

                      <div class="h-stack gap-4 justify-between">
                        <span class="h5">{{ 'cart.general.total' | t }}</span>
                        <span class="h5"
                          ><span class="bcpo-cart-original-total" data-safe-total="{{ safe_cart_total }}">
                            {{ safe_cart_total | money_with_currency }}
                            {% comment %} {{- cart.total_price | money_with_currency -}} {% endcomment %}
                          </span></span
                        >
                      </div>

                      {%- if block.settings.show_shipping_text -%}
                        {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                          <span class="text-subdued text-sm">
                            {{-
                              'cart.general.taxes_included_and_shipping_policy_html'
                              | t: link: shop.shipping_policy.url
                            -}}
                          </span>
                        {%- elsif cart.taxes_included -%}
                          <span class="text-subdued text-sm">
                            {{- 'cart.general.taxes_included_but_shipping_at_checkout' | t -}}
                          </span>
                        {%- elsif shop.shipping_policy.body != blank -%}
                          <span class="text-subdued text-sm">
                            {{-
                              'cart.general.taxes_and_shipping_policy_at_checkout_html'
                              | t: link: shop.shipping_policy.url
                            -}}
                          </span>
                        {%- else -%}
                          <span class="text-subdued text-sm">
                            {{- 'cart.general.taxes_and_shipping_at_checkout' | t -}}
                          </span>
                        {%- endif -%}
                      {%- endif -%}
                    </div>

                  {%- when 'cart_note' -%}
                    <cart-note class="cart-form__note block" {{ block.shopify_attributes }}>
                      {%- assign order_note = 'cart.general.order_note' | t -%}
                      {%- render 'input',
                        name: 'note',
                        multiline: 3,
                        label: order_note,
                        value: cart.note,
                        maxlength: block.settings.maxlength
                      -%}
                    </cart-note>

                  {%- when 'text' -%}
                    {%- if block.settings.content != blank -%}
                      <div class="prose text-subdued" {{ block.shopify_attributes }}>
                        {{- block.settings.content -}}
                      </div>
                    {%- endif -%}

                  {%- when 'offer' -%}
                    {%- assign previous_block_index = forloop.index0 | minus: 1 -%}
                    {%- assign next_block_index = forloop.index0 | plus: 1 -%}

                    {%- if section.blocks[next_block_index].type == 'offer' -%}
                      <div class="v-stack gap-4">
                    {%- endif -%}

                    {%- render 'offer', block: block -%}

                    {%- if section.blocks[previous_block_index].type == 'offer' -%}
                      </div>
                    {%- endif -%}

                  {%- when 'accelerated_buttons' -%}
                    {% if additional_checkout_buttons %}
                      <div
                        class="additional-checkout-buttons additional-checkout-buttons--vertical"
                        {{ block.shopify_attributes }}
                      >
                        {{- content_for_additional_checkout_buttons -}}
                      </div>
                    {% endif %}

                  {%- when 'checkout_button' -%}
                    <!-- {%- assign checkout_button = 'cart.general.checkout' | t -%} -->
                    <!--
                      {%- render 'button', type: 'submit', content: checkout_button, size: 'xl', name: 'checkout', stretch: true, block: block -%}
                    -->
                    <!--
                      <button type="button" id="checkout2" onclick="handleFloCheckoutBtn()" class="button button--xl w-full" name="checkout2">
                      {{ 'cart.general.checkout' | t }} </button>
                    -->
                    {% render 'gokwik-checkout' %}
                    {% comment %}
                      <!--                        <button  onclick="handleOcc(this)" type="button" class="button button--xl zecpe-btn" style="display : grid;place-items:center; height : 62px; max-height : 62px">
                                              <div class="lds-ring"><div>&nbsp;</div><div>&nbsp;</div><div>&nbsp;</div><div>&nbsp;</div></div>
                                                <span class="occ-btn-text" style="display : flex;align-items : center;justify-content : center;">
                                                  {{ 'cart.general.checkout' | t }}
                                                </span>
                                            </button>                  -->
                                            <button onclick="window.zecpeCheckFunctionAndCall ? window.zecpeCheckFunctionAndCall('handleOcc', this) : window.location.href = '/cart/checkout'; event.stopPropagation(); event.stopImmediatePropagation();" type="button" class="btn cart__checkout button button--xl zecpe-btn">
                                              <div id="lds-ring" style="height : 20px;"><div>&nbsp;</div><div>&nbsp;</div><div>&nbsp;</div><div>&nbsp;</div></div>
                                                <span class="occ-btn-text" style="display : flex;align-items : center;justify-content : center;">
                                                    {{ 'cart.general.checkout' | t }}
                                                </span>
                                            </button>
                    {% endcomment %}
                {%- endcase -%}
              {%- endfor -%}
            </form>

            {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
              <div class="v-stack gap-4">
                <span class="text-xs text-subdued text-center">{{ 'cart.general.we_accept' | t }}</span>

                <div class="h-stack gap-2 wrap justify-center">
                  {%- for type in shop.enabled_payment_types -%}
                    {{- type | payment_type_svg_tag -}}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </safe-sticky>
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

