<script>
  function updatePrices(cart) {
    const bundleProducts = [8001599865086, 8001573290238, 8001597571326];

    /* ---------- LINE ITEM PRICES (bundle aware) ---------- */
    cart.items.forEach((item) => {
      if (bundleProducts.includes(item.product_id)) return;

      let total = item.final_line_price;

      cart.items.forEach((sub) => {
        if (
          bundleProducts.includes(sub.product_id) &&
          sub.properties &&
          sub.properties._bundleid === item.properties?._bundleid
        ) {
          total += sub.final_line_price;
        }
      });

      const priceEl = document.querySelector(`.bcpo-cart-item-line-price[data-key="${item.key}"]`);

      if (priceEl) {
        priceEl.innerHTML = Shopify.formatMoney(total, '{{ shop.money_format }}');
      }
    });

    /* ---------- SUBTOTAL ---------- */
    document.querySelectorAll('.bcpo-cart-subtotal').forEach((el) => {
      el.innerHTML = Shopify.formatMoney(cart.items_subtotal_price, '{{ shop.money_format }}');
    });

    /* ---------- TOTAL (VISIBLE TOTAL) ---------- */
    document.querySelectorAll('.bcpo-cart-original-total').forEach((el) => {
  const safeTotal = el.dataset.safeTotal;
  if (safeTotal) {
    el.innerHTML = Shopify.formatMoney(safeTotal, '{{ shop.money_format }}');
  }
});

  }
</script>

<script>
  function updateMinusButtonState() {
    document.querySelectorAll('.cart-button').forEach((wrapper) => {
      const input = wrapper.querySelector('.quantity-input');
      const minus = wrapper.querySelector('.cart-mini');

      if (!input || !minus) return;

      const qty = parseInt(input.value) || 1;
      minus.disabled = qty <= 1;
    });
  }

  // 🔥 Initial state on page load
  document.addEventListener('DOMContentLoaded', updateMinusButtonState);

  document.addEventListener('click', function (e) {
    const plus = e.target.closest('.cart-plus');
    const minus = e.target.closest('.cart-mini');
    if (!plus && !minus) return;

    const wrapper = e.target.closest('.cart-button');
    if (!wrapper) return;

    const input = wrapper.querySelector('.quantity-input');
    if (!input) return;

    const key = input.dataset.lineKey;
    if (!key) return;

    let qty = parseInt(input.value) || 1;
    const max = input.hasAttribute('max') ? parseInt(input.getAttribute('max')) : null;

    if (plus && (!max || qty < max)) qty++;
    if (minus && qty > 1) qty--;

    if (qty === parseInt(input.value)) return;

    // 🔥 Optimistic UI update
    input.value = qty;
    updateMinusButtonState();

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty }),
    })
      .then(() => window.location.reload())
      .catch((err) => console.error('Cart update failed', err));
  });
</script>


{% comment %} <script>
  document.addEventListener('DOMContentLoaded', function () {
    fetch('/cart.js')
      .then((res) => res.json())
      .then((cart) => {
        let fixes = [];

        cart.items.forEach((item) => {
          // Only inventory-tracked & deny overselling
          if (
            item.inventory_management &&
            item.inventory_policy === 'deny'
          ) {
            const maxQty = item.variant_inventory_quantity;

            if (maxQty !== null && item.quantity > maxQty) {
              fixes.push(
                fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    id: item.key,
                    quantity: maxQty
                  })
                })
              );
            }
          }
        });

        if (fixes.length) {
          Promise.all(fixes).then(() => {
            window.location.reload();
          });
        }
      })
      .catch((e) => console.error('Cart stock sync failed', e));
  });
</script> {% endcomment %}

