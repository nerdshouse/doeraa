                                                  <div class="st-ProductItem-Info">
                                                      <div class="st-p-color">
                                                          <a class=""> <span style="cursor: pointer; background-image: linear-gradient(to right, rgb(61, 62, 60) 50%, rgb(61, 62, 60) 50%);"></span> </a>
                                                      </div>
