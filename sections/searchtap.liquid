                                                      <span v-else :class="['final-price',(product.discount>0)?'st-discount-price':'']">{{ currencySymbol }} {{ getPrice(product.activeVariant.activeCurrencyDiscountedPrice) }}<span class="st-unit-text" v-if="getUnit(product.tags)">/{{ getUnit(product.tags) }}</span></span>
