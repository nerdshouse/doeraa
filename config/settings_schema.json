[
  {
    "name": "theme_info",
    "theme_name": "Impact",
    "theme_author": "Maestrooo",
    "theme_version": "3.0.0",
    "theme_documentation_url": "https://support.maestrooo.com/",
    "theme_support_url": "https://support.maestrooo.com/article/203-contact-us"
